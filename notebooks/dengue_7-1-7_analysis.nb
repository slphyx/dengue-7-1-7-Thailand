Cell["\<\
This notebook reproduces analyses in : \"How much could faster outbreak \
response reduce dengue burden? 
A 7-1-7\[Dash]inspired analysis using national surveillance data from \
Thailand.\"\
\>", "Text",
 CellChangeTimes->{{3.980892909554119*^9, 
  3.980892918424011*^9}},ExpressionUUID->"3a489d0a-1e63-ce49-b567-\
