              "Below"}], "]"}]}], ",", 
           RowBox[{"PlotLabel", "->", "Y"}]}], "]"}]}], "\[IndentingNewLine]",
         "]"}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}]}]], "Input",
