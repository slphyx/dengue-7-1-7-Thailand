Cell[BoxData[
 RowBox[{
  RowBox[{"ab80", "=", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{"Function", "[", 
      RowBox[{"r", ",", 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"w", "=", 
           RowBox[{"r", "[", "\"\<week\>\"", "]"}]}], "}"}], ",", 
         RowBox[{"Join", "[", 
          RowBox[{"r", ",", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<baseline\>\"", "->", 
              RowBox[{"baselineByWeek", "[", "w", "]"}]}], ",", 
             RowBox[{"\"\<threshold\>\"", "->", 
              RowBox[{
               RowBox[{"thresholdByWeek", "[", 
                RowBox[{"[", "3", "]"}], "]"}], "[", "w", "]"}]}], ",", 
             RowBox[{"\"\<above\>\"", "->", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"r", "[", "\"\<cases\>\"", "]"}], ">", 
                RowBox[{
                 RowBox[{"thresholdByWeek", "[", 
                  RowBox[{"[", "3", "]"}], "]"}], "[", "w", "]"}]}], 
               ")"}]}]}], "|>"}]}], "]"}]}], "]"}]}], "]"}], ",", "data"}], 
    "]"}]}], ";"}]], "Input",
 CellLabel->"In[15]:=",ExpressionUUID->"abb7d4d4-5167-7040-b0d4-2634539cb4ae"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "find", " ", "the", " ", "positions", " ", "that", " ", "the", " ", 
    "dengue", " ", "cases", " ", "were", " ", "above", " ", "the", " ", 
    "threshold", " ", 
    RowBox[{"(", 
     RowBox[{"at", " ", "80", "%"}], ")"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"FindOutBreak", "[", "Y_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"trsh", ",", "atyr"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"trsh", "=", 
        RowBox[{
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"Normal", "@", 
            RowBox[{
             RowBox[{"Select", "[", 
              RowBox[{"ab80", ",", 
               RowBox[{
                RowBox[{"#year", "==", "Y"}], "&"}]}], "]"}], "[", 
             RowBox[{"All", ",", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"#week", ",", "#cases", ",", "#above"}], "}"}], 
               "&"}]}], "]"}]}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"#", "[", 
              RowBox[{"[", "3", "]"}], "]"}], "==", "True"}], "&"}]}], "]"}], 
         "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"atyr", "=", 
        RowBox[{
         RowBox[{"Select", "[", 
          RowBox[{"ab80", ",", 
           RowBox[{
            RowBox[{"#year", "==", "Y"}], "&"}]}], "]"}], "[", 
         RowBox[{"All", ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"#week", ",", "#cases"}], "}"}], "&"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"trsh", "!=", 
          RowBox[{"{", "}"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"ListPlot", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"thresholdByWeek", "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", "atyr", ",", "trsh"}], 
            "}"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Joined", "->", 
            RowBox[{"{", 
             RowBox[{"True", ",", " ", "True", ",", "False"}], "}"}]}], ",", 
           RowBox[{"PlotStyle", "->", 
            RowBox[{"{", 
             RowBox[{"Automatic", ",", "Automatic", ",", 
              RowBox[{"{", 
               RowBox[{"Red", ",", 
                RowBox[{"PointSize", "[", "0.02", "]"}]}], "}"}]}], "}"}]}], ",",
            "\[IndentingNewLine]", 
           RowBox[{"PlotRange", "->", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"0", ",", "55"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"0", ",", "8000"}], "}"}]}], "}"}]}], ",", 
           RowBox[{"Frame", "->", "True"}], ",", 
           RowBox[{"GridLines", "->", "Automatic"}], ",", 
           RowBox[{"FrameLabel", "->", 
            RowBox[{"{", 
             RowBox[{"\"\<Week\>\"", ",", " ", "\"\<Cases\>\""}], "}"}]}], ",", 
           RowBox[{"PlotLegends", "->", 
            RowBox[{"Placed", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"\"\<threshold at 80%\>\"", ",", 
                RowBox[{"\"\<data at \>\"", "<>", 
                 RowBox[{"ToString", "[", "Y", "]"}]}], 
                ",", "\"\<Outbreak\>\""}], "}"}], ",", " ", "Below"}], 
             "]"}]}], ",", 
           RowBox[{"PlotLabel", "->", "Y"}], ",", 
           RowBox[{"ImageSize", "->", "Medium"}]}], "]"}], 
         "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
         RowBox[{"ListPlot", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"thresholdByWeek", "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", "atyr"}], "}"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Joined", "->", 
            RowBox[{"{", 
             RowBox[{"True", ",", " ", "True", ",", "False"}], "}"}]}], ",", 
           RowBox[{"PlotStyle", "->", 
            RowBox[{"{", 
             RowBox[{"Automatic", ",", "Automatic", ",", 
              RowBox[{"{", 
               RowBox[{"Red", ",", 
                RowBox[{"PointSize", "[", "0.025", "]"}]}], "}"}]}], "}"}]}], 
           ",", "\[IndentingNewLine]", 
           RowBox[{"PlotRange", "->", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"0", ",", "55"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"0", ",", "8000"}], "}"}]}], "}"}]}], ",", 
           RowBox[{"Frame", "->", "True"}], ",", 
           RowBox[{"GridLines", "->", "Automatic"}], ",", 
           RowBox[{"FrameLabel", "->", 
            RowBox[{"{", 
