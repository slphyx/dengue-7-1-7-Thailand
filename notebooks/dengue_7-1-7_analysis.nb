      RowBox[{"runs", "=", 
       RowBox[{"Select", "[", 
        RowBox[{
         RowBox[{"Split", "[", 
          RowBox[{
           RowBox[{"trsh", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
           RowBox[{
            RowBox[{"#2", "==", 
             RowBox[{"#1", "+", "1"}]}], "&"}]}], "]"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "#", "]"}], ">=", "2"}], "&"}]}], "]"}]}], ";",
       "\n", 
      RowBox[{"intervals", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"First", "[", "#", "]"}], ",", 
           RowBox[{"Last", "[", "#", "]"}]}], "}"}], "&"}], "/@", "runs"}]}], 
      ";", "\n", 
      RowBox[{"lengths", "=", 
       RowBox[{"Length", "/@", "runs"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Thread", "[", 
           RowBox[{"{", 
            RowBox[{"#", ",", 
             RowBox[{"Lookup", "[", 
              RowBox[{"trshass", ",", "#"}], "]"}]}], "}"}], "]"}], "&"}], "/@",
          "runs"}], ",", "1"}], "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"yr", ",", 
       RowBox[{"{", 
        RowBox[{"2019", ",", "2023", ",", "2024"}], "}"}]}], "}"}]}], 
