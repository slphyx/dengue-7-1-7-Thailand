Cell[BoxData[
 RowBox[{
  RowBox[{"ab80", "=", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{"Function", "[", 
      RowBox[{"r", ",", 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"w", "=", 
           RowBox[{"r", "[", "\"\<week\>\"", "]"}]}], "}"}], ",", 
         RowBox[{"Join", "[", 
          RowBox[{"r", ",", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<baseline\>\"", "->", 
              RowBox[{"baselineByWeek", "[", "w", "]"}]}], ",", 
             RowBox[{"\"\<threshold\>\"", "->", 
              RowBox[{
               RowBox[{"thresholdByWeek", "[", 
                RowBox[{"[", "3", "]"}], "]"}], "[", "w", "]"}]}], ",", 
             RowBox[{"\"\<above\>\"", "->", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"r", "[", "\"\<cases\>\"", "]"}], ">", 
                RowBox[{
                 RowBox[{"thresholdByWeek", "[", 
                  RowBox[{"[", "3", "]"}], "]"}], "[", "w", "]"}]}], 
               ")"}]}]}], "|>"}]}], "]"}]}], "]"}]}], "]"}], ",", "data"}], 
    "]"}]}], ";"}]], "Input",ExpressionUUID->"abb7d4d4-5167-7040-b0d4-\
2634539cb4ae"],

Cell[BoxData[
 RowBox[{"outbreak80", "=", 
  RowBox[{"Table", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"trsh", "=", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{
         RowBox[{"Normal", "@", 
          RowBox[{
           RowBox[{"Select", "[", 
            RowBox[{"ab80", ",", 
             RowBox[{
              RowBox[{"#year", "==", "yr"}], "&"}]}], "]"}], "[", 
           RowBox[{"All", ",", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"#week", ",", "#cases", ",", "#above"}], "}"}], "&"}]}],
            "]"}]}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "3", "]"}], "]"}], "==", "True"}], "&"}]}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"trshass", "=", 
      RowBox[{"Association", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"#1", "->", "#2"}], "&"}], "@@@", "trsh"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"runs", "=", 
      RowBox[{"Select", "[", 
       RowBox[{
        RowBox[{"Split", "[", 
         RowBox[{
          RowBox[{"trsh", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"#2", "==", 
            RowBox[{"#1", "+", "1"}]}], "&"}]}], "]"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "#", "]"}], ">=", "2"}], "&"}]}], "]"}]}], ";",
      "\n", 
     RowBox[{"intervals", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"First", "[", "#", "]"}], ",", 
          RowBox[{"Last", "[", "#", "]"}]}], "}"}], "&"}], "/@", "runs"}]}], ";",
      "\n", 
     RowBox[{"lengths", "=", 
      RowBox[{"Length", "/@", "runs"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Thread", "[", 
          RowBox[{"{", 
           RowBox[{"#", ",", 
            RowBox[{"Lookup", "[", 
             RowBox[{"trshass", ",", "#"}], "]"}]}], "}"}], "]"}], "&"}], "/@",
         "runs"}], ",", "1"}], "]"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"yr", ",", 
      RowBox[{"{", 
       RowBox[{"2019", ",", "2023", ",", "2024"}], "}"}]}], "}"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.978565717446745*^9, 3.978565727130972*^9}, {
  3.978565837344244*^9, 3.9785658377533855`*^9}, {3.979680698836218*^9, 
  3.9796806996947727`*^9}, {3.979680970435379*^9, 3.979681046153269*^9}, {
  3.9796811210734596`*^9, 3.979681142888994*^9}, {3.9796812718213673`*^9, 
  3.979681328283001*^9}},
 CellLabel->
