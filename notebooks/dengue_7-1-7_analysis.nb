Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"BootstrapSamples", "[", 
     RowBox[{"ds_Dataset", ",", "makeCF_", ",", 
      RowBox[{"n_Integer", ":", "5000"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rows", "=", 
         RowBox[{"Normal", "[", "ds", "]"}]}], ",", "m", ",", "totals"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"m", "=", 
        RowBox[{"Length", "[", "rows", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"totals", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"sample", ",", "cf"}], "}"}], ",", 
            RowBox[{
             RowBox[{"sample", "=", 
              RowBox[{"RandomChoice", "[", 
               RowBox[{"rows", ",", "m"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"cf", "=", 
              RowBox[{"makeCF", "[", 
               RowBox[{"Dataset", "[", "sample", "]"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"Total", "[", 
              RowBox[{"Normal", "[", 
               RowBox[{"cf", "[", 
                RowBox[{"All", ",", "\"\<cases_averted\>\""}], "]"}], "]"}], 
              "]"}]}]}], "]"}], ",", 
          RowBox[{"{", "n", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
