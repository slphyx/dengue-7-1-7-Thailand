Cell[BoxData[{
 RowBox[{
  RowBox[{"targetQ", "=", "0.25"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"targetDur", "=", 
    RowBox[{"Quantile", "[", 
     RowBox[{
      RowBox[{"Normal", "[", 
       RowBox[{"epi", "[", 
        RowBox[{"All", ",", "\"\<duration\>\""}], "]"}], "]"}], ",", 
      "targetQ"}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ShortenToTarget", "[", 
     RowBox[{"ds_Dataset", ",", 
      RowBox[{"target_Integer", "?", "Positive"}]}], "]"}], ":=", 
    RowBox[{"ds", "[", 
     RowBox[{"All", ",", 
      RowBox[{"Function", "[", 
       RowBox[{"row", ",", 
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"d", "=", 
             RowBox[{"row", "[", "\"\<duration\>\"", "]"}]}], ",", 
            RowBox[{"tc", "=", 
             RowBox[{"row", "[", "\"\<total_cases\>\"", "]"}]}], ",", "d2", ",",
             "tc2"}], "}"}], ",", 
          RowBox[{
           RowBox[{"d2", "=", 
            RowBox[{"Min", "[", 
             RowBox[{"d", ",", "target"}], "]"}]}], ";", 
           RowBox[{"(*", 
            RowBox[{
             RowBox[{"only", " ", "shorten"}], ",", 
             RowBox[{"never", " ", "lengthen"}]}], "*)"}], 
           "\[IndentingNewLine]", 
           RowBox[{"tc2", "=", 
            RowBox[{"tc", "*", 
             RowBox[{"(", 
              RowBox[{"d2", "/", "d"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"Join", "[", 
            RowBox[{"row", ",", 
             RowBox[{"<|", 
              RowBox[{
               RowBox[{"\"\<cf_duration\>\"", "->", "d2"}], ",", 
               RowBox[{"\"\<cf_total_cases\>\"", "->", "tc2"}], ",", 
               RowBox[{"\"\<cases_averted\>\"", "->", 
                RowBox[{"(", 
                 RowBox[{"tc", "-", "tc2"}], ")"}]}], ",", 
               RowBox[{"\"\<pct_averted\>\"", "->", 
                RowBox[{"100.0", "*", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"tc", "-", "tc2"}], ")"}], "/", "tc"}]}]}]}], 
              "|>"}]}], "]"}]}]}], "]"}]}], "]"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cfTarget", "=", 
   RowBox[{"ShortenToTarget", "[", 
    RowBox[{"epi", ",", 
     RowBox[{"Round", "[", "targetDur", "]"}]}], "]"}]}], 
  ";"}], "\n", "cfTarget", "\n"}], "Input",
