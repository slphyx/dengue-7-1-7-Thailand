Cell[BoxData[
 RowBox[{
  RowBox[{"byYW", "=", 
   RowBox[{
    RowBox[{"Query", "[", 
     RowBox[{
      RowBox[{"GroupBy", "[", 
       RowBox[{"#year", "&"}], "]"}], ",", 
      RowBox[{"GroupBy", "[", 
       RowBox[{"#week", "&"}], "]"}], ",", "All", ",", 
      RowBox[{"#cases", "&"}]}], "]"}], "[", "data", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9786437449172*^9, 3.9786439147758636`*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"c576994b-e289-9c48-b372-5f5d36e04e32"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"q", "=", 
   RowBox[{"{", 
    RowBox[{"0.70", ",", "0.75", ",", "0.80", ",", "0.85", ",", "0.90"}], 
    "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"baselineByWeek", "=", 
   RowBox[{
    RowBox[{"Query", "[", 
     RowBox[{
      RowBox[{"GroupBy", "[", 
       RowBox[{"#week", "&"}], "]"}], ",", "Median", ",", 
      RowBox[{"#cases", "&"}]}], "]"}], "[", "data", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"thresholdByWeek", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Query", "[", 
       RowBox[{
        RowBox[{"GroupBy", "[", 
         RowBox[{"#week", "&"}], "]"}], ",", 
        RowBox[{
         RowBox[{"Quantile", "[", 
          RowBox[{"#", ",", "j"}], "]"}], "&"}], ",", 
        RowBox[{"#cases", "&"}]}], "]"}], "[", "data", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "q"}], "}"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9784729434075356`*^9, 3.9784729434075356`*^9}, {
   3.9784868418798676`*^9, 3.9784868803800697`*^9}, {3.9784897266566086`*^9, 
