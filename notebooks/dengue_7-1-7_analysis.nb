Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"BootstrapAverted", "[", 
    RowBox[{"ds_Dataset", ",", "makeCF_", ",", 
     RowBox[{"n_Integer", ":", "5000"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"rows", "=", 
        RowBox[{"Normal", "[", "ds", "]"}]}], ",", 
       RowBox[{"m", "=", 
        RowBox[{"Length", "[", 
         RowBox[{"Normal", "[", "ds", "]"}], "]"}]}], ",", "totals"}], "}"}], 
     ",", 
     RowBox[{
      RowBox[{"totals", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"sample", ",", "cf"}], "}"}], ",", 
           RowBox[{
            RowBox[{"sample", "=", 
             RowBox[{"RandomChoice", "[", 
              RowBox[{"rows", ",", "m"}], "]"}]}], ";", 
            RowBox[{"(*", 
             RowBox[{
             "resample", " ", "rows", " ", "with", " ", "replacement"}], 
             "*)"}], "\[IndentingNewLine]", 
            RowBox[{"cf", "=", 
             RowBox[{"makeCF", "[", 
              RowBox[{"Dataset", "[", "sample", "]"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"Total", "[", 
             RowBox[{"Normal", "[", 
              RowBox[{"cf", "[", 
               RowBox[{"All", ",", "\"\<cases_averted\>\""}], "]"}], "]"}], 
             "]"}]}]}], "]"}], ",", 
         RowBox[{"{", "n", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<mean_averted\>\"", "->", 
         RowBox[{"Mean", "[", "totals", "]"}]}], ",", 
        RowBox[{"\"\<median_averted\>\"", "->", 
         RowBox[{"Median", "[", "totals", "]"}]}], ",", 
        RowBox[{"\"\<CI95\>\"", "->", 
         RowBox[{"Quantile", "[", 
          RowBox[{"totals", ",", 
           RowBox[{"{", 
            RowBox[{"0.025", ",", "0.975"}], "}"}]}], "]"}]}]}], "|>"}]}]}], 
    "]"}]}], ";"}]], "Input",
