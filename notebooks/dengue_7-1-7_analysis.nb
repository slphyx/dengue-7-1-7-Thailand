Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "consecutiveIntervals", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"consecutiveIntervals", "[", 
   RowBox[{"trshlist_", ",", 
    RowBox[{"minLen_", ":", "2"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "runs", ",", "list", ",", "assc", ",", "tot", ",", "max", ",", 
      "t2peak"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"assc", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"#1", "->", "#2"}], "&"}], "@@@", "trshlist"}], ")"}], "//",
        "Association"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"list", "=", 
      RowBox[{"trshlist", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"runs", "=", 
      RowBox[{"Select", "[", 
       RowBox[{
        RowBox[{"Split", "[", 
         RowBox[{"list", ",", 
          RowBox[{
           RowBox[{"#2", "==", 
            RowBox[{"#1", "+", "1"}]}], "&"}]}], "]"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "#", "]"}], ">=", "minLen"}], "&"}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"tot", "=", 
      RowBox[{"Total", "/@", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Lookup", "[", 
           RowBox[{"assc", ",", "#"}], "]"}], "&"}], "/@", "runs"}], 
        ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"max", "=", 
      RowBox[{"Max", "/@", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Lookup", "[", 
           RowBox[{"assc", ",", "#"}], "]"}], "&"}], "/@", "runs"}], 
        ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"t2peak", "=", 
      RowBox[{
       RowBox[{"PositionLargest", "/@", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"Lookup", "[", 
            RowBox[{"assc", ",", "#"}], "]"}], "&"}], "/@", "runs"}], ")"}]}],
        "-", "1"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<Intervals\>\"", "->", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"First", "[", "#", "]"}], ",", 
             RowBox[{"Last", "[", "#", "]"}]}], "}"}], "&"}], "/@", "runs"}], 
         ")"}]}], ",", 
       RowBox[{"\"\<Lengths\>\"", "->", 
        RowBox[{"(", 
         RowBox[{"Length", "/@", "runs"}], ")"}]}], ",", 
       RowBox[{"\"\<total\>\"", "->", "tot"}], ",", 
       RowBox[{"\"\<Maximum\>\"", "->", "max"}], ",", 
       RowBox[{"\"\<Time2Peak\>\"", "->", "t2peak"}]}], "|>"}]}]}], 
   "]"}]}], "\n"}], "Input",
 CellChangeTimes->{{3.9785658910566406`*^9, 3.9785658910566406`*^9}, {
   3.9785696255309124`*^9, 3.978569660836315*^9}, {3.978569702533268*^9, 
   3.9785697989661236`*^9}, {3.978569831203373*^9, 3.9785698377151737`*^9}, {
