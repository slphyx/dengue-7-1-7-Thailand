Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"RandomAchievableCF", "[", 
     RowBox[{"ds_Dataset", ",", 
      RowBox[{"bestFrac_", ":", "0.5"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rows", "=", 
         RowBox[{"Normal", "[", "ds", "]"}]}], ",", "dAll", ",", "pool", ",", 
        "target"}], "}"}], ",", 
      RowBox[{
       RowBox[{"dAll", "=", 
        RowBox[{"Normal", "[", 
         RowBox[{"ds", "[", 
          RowBox[{"All", ",", "\"\<duration\>\""}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"pool", "=", 
        RowBox[{"TakeSmallest", "[", 
         RowBox[{"dAll", ",", 
          RowBox[{"Max", "[", 
           RowBox[{"1", ",", 
            RowBox[{"Ceiling", "[", 
             RowBox[{"bestFrac", "*", 
              RowBox[{"Length", "[", "dAll", "]"}]}], "]"}]}], "]"}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "randomly", " ", "pick", " ", "an", " ", "achievable", " ", "target", 
         " ", "duration"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"target", "=", 
        RowBox[{"RandomChoice", "[", "pool", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"ShortenToTarget", "[", 
        RowBox[{"ds", ",", "target"}], "]"}]}]}], "\[IndentingNewLine]", 
     "]"}]}], ";"}], "\n"}]], "Input",
 CellChangeTimes->{{3.9785726464348774`*^9, 3.9785726634255276`*^9}, {
  3.9785752266124744`*^9, 3.9785752416477146`*^9}},
 CellLabel->
  "In[257]:=",ExpressionUUID->"28fc827c-b57e-1649-9bba-ce85d0649a97"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SimulateAvertedDistribution", "[", 
     RowBox[{"ds_Dataset", ",", 
      RowBox[{"bestFrac_", ":", "0.5"}], ",", 
      RowBox[{"n_Integer", ":", "5000"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "totals", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"totals", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Total", "[", 
           RowBox[{"Normal", "[", 
            RowBox[{
             RowBox[{"RandomAchievableCF", "[", 
              RowBox[{"ds", ",", "bestFrac"}], "]"}], "[", 
             RowBox[{"All", ",", "\"\<cases_averted\>\""}], "]"}], "]"}], 
           "]"}], ",", 
          RowBox[{"{", "n", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<median_averted\>\"", "->", 
          RowBox[{"Median", "[", "totals", "]"}]}], ",", 
         RowBox[{"\"\<IQR\>\"", "->", 
          RowBox[{"Quantile", "[", 
           RowBox[{"totals", ",", 
            RowBox[{"{", 
             RowBox[{"0.25", ",", "0.75"}], "}"}]}], "]"}]}], ",", 
         RowBox[{"\"\<CI95\>\"", "->", 
          RowBox[{"Quantile", "[", 
           RowBox[{"totals", ",", 
            RowBox[{"{", 
             RowBox[{"0.025", ",", "0.975"}], "}"}]}], "]"}]}]}], "|>"}]}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], "\n"}]], "Input",
